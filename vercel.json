{
    "version": 2,
    "builds": [
        {
            "src": "frontend_web/package.json",
            "use": "@vercel/next"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "frontend_web/$1"
        }
    ],
    "env": {
        "NEXT_PUBLIC_API_BASE_URL": "@api_base_url",
        "NEXT_PUBLIC_SOCKET_URL": "@socket_url",
        "NEXT_PUBLIC_APP_URL": "@app_url"
    }
}